# =============================================================================
# リポジトリ全体の .gitignore(全サンプル共通)
# =============================================================================

# --- Python / 開発環境 ---
__pycache__/
*.pyc
*.pyo
.venv/
.ipynb_checkpoints/

# --- OS / エディタ ---
.DS_Store
*.swp

# --- 学習成果物(host に出力した場合。通常は Docker volume 管理なので出ない)---
**/models/*.joblib
**/models/*.json

# --- sample4: make data / prep が生成・DL する成果物(大きい・再生成可能)---
#     ディレクトリ自体はマウント用に .gitkeep で残す。
004_mlops_roadmesh_streaming/data/road/*.graphml
004_mlops_roadmesh_streaming/data/geojson/
004_mlops_roadmesh_streaming/08_grafana/geojson/*.geojson
